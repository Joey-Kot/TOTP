# Required when ONLY_TOTP=false.
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=pbkdf2:sha256:1000000$...$...

# Required.
TOTP_SECRET=BASE32TOTPSECRET
COOKIE_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Runtime options.
LISTEN_ADDR=127.0.0.1:9092
COOKIE_NAME=izual_auth
COOKIE_DOMAIN=.example.com
COOKIE_MAX_AGE=168h
DEFAULT_REDIRECT=https://auth.example.com/
SECURE_COOKIE=true
ONLY_TOTP=false
ALLOWED_REDIRECT_HOSTS=.example.com
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=5m
